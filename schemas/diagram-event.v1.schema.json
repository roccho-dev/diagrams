{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/jsonl-diagram/diagram-event.v1.schema.json",
  "title": "Diagram Event v1",
  "type": "object",
  "required": ["op"],
  "additionalProperties": true,
  "properties": {
    "op": {
      "enum": [
        "diagram.init",
        "group.upsert",
        "node.upsert",
        "edge.upsert",
        "task.upsert",
        "entity.upsert",
        "milestone.upsert",
        "style.intent",
        "layout.intent",
        "label.update",
        "edge.reconnect",
        "lane.assign",
        "span.update",
        "visual.position.set",
        "visual.edge.bendpoint.set"
      ]
    },
    "id": { "$ref": "#/$defs/id" },
    "target": { "$ref": "#/$defs/id" },
    "source": { "$ref": "#/$defs/id" },
    "target": { "$ref": "#/$defs/id" },
    "kind": { "$ref": "#/$defs/id" },
    "lane": { "$ref": "#/$defs/id" },
    "label": { "type": "string" },
    "intent": { "$ref": "#/$defs/id" },
    "start": { "type": "integer" },
    "end": { "type": "integer" },
    "order": { "type": "integer" },
    "x": { "type": "number" },
    "y": { "type": "number" },
    "w": { "type": "number" },
    "h": { "type": "number" },
    "lock": { "type": "boolean" },
    "sourceCommandId": { "$ref": "#/$defs/id" },
    "points": { "type": "array", "items": { "$ref": "#/$defs/point" } },
    "meta": { "type": "object", "additionalProperties": true }
  },
  "allOf": [
    { "if": { "properties": { "op": { "const": "diagram.init" } } }, "then": { "required": ["op", "id", "kind", "label"] } },
    { "if": { "properties": { "op": { "const": "group.upsert" } } }, "then": { "required": ["op", "id", "kind", "label"] } },
    { "if": { "properties": { "op": { "const": "node.upsert" } } }, "then": { "required": ["op", "id", "kind", "label"] } },
    { "if": { "properties": { "op": { "const": "edge.upsert" } } }, "then": { "required": ["op", "id", "source", "target"] } },
    { "if": { "properties": { "op": { "const": "task.upsert" } } }, "then": { "required": ["op", "id", "lane", "start", "end", "label"], "properties": { "end": { "exclusiveMinimum": 0 } } } },
    { "if": { "properties": { "op": { "const": "entity.upsert" } } }, "then": { "required": ["op", "id", "kind", "label", "meta"] } },
    { "if": { "properties": { "op": { "const": "milestone.upsert" } } }, "then": { "required": ["op", "id", "kind", "label"] } },
    { "if": { "properties": { "op": { "const": "style.intent" } } }, "then": { "required": ["op", "target", "intent"] } },
    { "if": { "properties": { "op": { "const": "layout.intent" } } }, "then": { "required": ["op", "target", "intent"] } },
    { "if": { "properties": { "op": { "const": "label.update" } } }, "then": { "required": ["op", "target", "label"] } },
    { "if": { "properties": { "op": { "const": "edge.reconnect" } } }, "then": { "required": ["op", "id", "source", "target"] } },
    { "if": { "properties": { "op": { "const": "lane.assign" } } }, "then": { "required": ["op", "id", "lane"] } },
    { "if": { "properties": { "op": { "const": "span.update" } } }, "then": { "required": ["op", "id", "start", "end"] } },
    { "if": { "properties": { "op": { "const": "visual.position.set" } } }, "then": { "required": ["op", "target", "x", "y"] } },
    { "if": { "properties": { "op": { "const": "visual.edge.bendpoint.set" } } }, "then": { "required": ["op", "id", "points"] } }
  ],
  "$defs": {
    "id": { "type": "string", "minLength": 1, "pattern": "^[^\\n\\r\\t]+$" },
    "point": {
      "type": "object",
      "required": ["x", "y"],
      "additionalProperties": false,
      "properties": { "x": { "type": "number" }, "y": { "type": "number" } }
    }
  }
}
